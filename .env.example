# Proxmox Host (primary node)
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_VERIFY_SSL=false
# Optional: fallback nodes tried automatically if the primary is unreachable (comma-separated)
PROXMOX_FALLBACK_HOSTS=192.168.1.101,192.168.1.102

# API Token (create under Datacenter > Permissions > API Tokens)
# Format: user@realm!tokenid
PROXMOX_TOKEN_ID=root@pam!deploy
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

APP_SECRET=change-this-to-a-random-string

# SSH (for maintenance mode, community scripts, rolling updates)
# Docker: set SSH_KEY_PATH to the path of your private key on the HOST machine.
#         It will be mounted read-only into the container at /ssh/id_rsa.
SSH_PORT=22
SSH_USER=root
SSH_KEY_PATH=/root/.ssh/id_rsa
SSH_PASSWORD=

# Optional: override SSH host IP per node when node names are not DNS-resolvable
# SSH_HOST_PMX1=10.0.0.1
# SSH_HOST_PMX2=10.0.0.2

# --- Let's Encrypt (optional) ---
# Required when using docker/letsencrypt-init.sh
DOMAIN=proxmox.example.com
LETSENCRYPT_EMAIL=admin@example.com

# --- EntraID / Azure AD (optional - leave empty to disable) ---
ENTRAID_TENANT_ID=
ENTRAID_CLIENT_ID=
ENTRAID_CLIENT_SECRET=
ENTRAID_REDIRECT_URI=
